def make_state_badge_html(pr):
    state = effective_state(pr)
    cls = f"state state-{state.lower()}"
    return f'<span class="{cls}">{state.lower()}</span>'


def make_node_card_html(branch, pr, is_root=False, is_target=False):
    b_url = branch_url(branch)
    leaf_cls = "leaf" + (" root" if is_root else "") + (" target" if is_target else "")
    branch_link_cls = "branch-link" + (" root" if is_root else "") + (" target" if is_target else "")

    if is_root:
        return (
            f'<div class="{leaf_cls}">'
            f'<a class="{branch_link_cls}" href="{esc(b_url)}" target="_blank">{esc(branch)}</a>'
            f'</div>'
        )

    if pr:
        badge = make_state_badge_html(pr)
        issues = get_linked_issues(pr["number"])
        issue_lines = "".join(
            f'<span class="pr-line">'
            f'<a class="issue-link" href="{esc(issue["url"])}" target="_blank">#{issue["number"]}</a>'
            f'<a class="text-link" href="{esc(issue["url"])}" target="_blank">{esc(issue["title"])}</a>'
            f'</span>'
            for issue in issues
        )
        pr_line = (
            f'{issue_lines}'
            f'<span class="pr-line">'
            f'{badge}'
            f'<a class="pr-link" href="{esc(pr["url"])}" target="_blank">#{pr["number"]}</a>'
            f'<a class="text-link" href="{esc(pr["url"])}" target="_blank">{esc(pr["title"])}</a>'
            f'</span>'
        )
    else:
        pr_line = '<span class="pr-line"><span class="no-pr">(no PR)</span></span>'

    branch_line = (
        f'<span class="branch-line">'
        f'<a class="{branch_link_cls}" href="{esc(b_url)}" target="_blank">{esc(branch)}</a>'
        f'</span>'
    )
    return f'<div class="{leaf_cls}">{pr_line}{branch_line}</div>'


def subtree_trunk_html(prs, base_to_prs, visited, target_branch):
    rows = []
    for pr in prs:
        if pr["number"] in visited:
            continue
        visited.add(pr["number"])
        is_target = (pr["headRefName"] == target_branch)
        card = make_node_card_html(pr["headRefName"], pr, is_target=is_target)
        children = base_to_prs.get(pr["headRefName"], [])
        child_trunk = subtree_trunk_html(children, base_to_prs, visited, target_branch)
        rows.append(
            f'<div class="node-row">'
            f'<div class="branch"></div>'
            f'<div class="node-content">{card}{child_trunk}</div>'
            f'</div>'
        )
    if not rows:
        return ""
    return '<div class="trunk">' + "".join(rows) + "</div>"


def output_html(chain, target_branch, base_to_prs):
    visited = set()
    root_branch = chain[0][0]
    root_card = make_node_card_html(root_branch, None, is_root=True)

    if len(chain) < 2:
        return HTML_TEMPLATE.format(target=esc(target_branch), tree_html=root_card)

    # L1
    l1_branch, l1_pr = chain[1]
    is_target = (l1_branch == target_branch)
    if l1_pr:
        visited.add(l1_pr["number"])
    l1_card = make_node_card_html(l1_branch, l1_pr, is_target=is_target)

    # L2以降: 全子孫を網羅
    children = base_to_prs.get(l1_branch, [])
    child_trunk = subtree_trunk_html(children, base_to_prs, visited, target_branch)

    l1_trunk = (
        '<div class="trunk">'
        '<div class="node-row">'
        '<div class="branch"></div>'
        f'<div class="node-content">{l1_card}{child_trunk}</div>'
        '</div>'
        '</div>'
    )
    return HTML_TEMPLATE.format(target=esc(target_branch), tree_html=root_card + l1_trunk)


# ===== メイン =====

def main():
    parser = argparse.ArgumentParser(
        prog="pr-tree",
        description="PRの親子関係をツリー表示します"
    )
    parser.add_argument("branch", nargs="?", default=None, help="対象ブランチ（省略時はカレント）")
    parser.add_argument("--open", action="store_true", help="HTMLを生成してブラウザで開く")
    parser.add_argument("--root", default=None, help="ルートブランチを指定（.pr-treeに保存）")
    args = parser.parse_args()

    global ROOT_BRANCH
    if args.root:
        ROOT_BRANCH = args.root
        save_root_branch(args.root)
    else:
        saved = load_root_branch()
        if saved:
            ROOT_BRANCH = saved

    branch = args.branch or run(["git", "branch", "--show-current"])
    if not branch:
        print("Error: カレントブランチを取得できません", file=sys.stderr)
        sys.exit(1)

    prs = load_all_prs()
    head_to_pr, base_to_prs = build_maps(prs)
    chain = collect_chain(branch, head_to_pr)

    print(file=sys.stderr)

    if args.open:
        html = output_html(chain, branch, base_to_prs)
        safe_name = re.sub(r'[^\w\-.]', '_', branch)
        path = f"/tmp/pr-tree-{safe_name}.html"
        with open(path, "w") as f:
            f.write(html)
        print(f"Opening {path} ...", file=sys.stderr)
        subprocess.run(["open", path])
    else:
        output_cli(chain, branch, head_to_pr, base_to_prs)


if __name__ == "__main__":
    main()