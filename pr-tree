#!/usr/bin/env python3
# pr-tree: PRの親子関係をツリー表示する
# Usage: pr-tree [--open] [branch]
# 依存: gh (GitHub CLI), git

import subprocess
import sys
import json
import argparse
import os
import re
from urllib.parse import quote

BOLD  = '\033[1m'
CYAN  = '\033[0;36m'
GREEN = '\033[0;32m'
YELLOW = '\033[0;33m'
MAGENTA = '\033[0;35m'
RED   = '\033[0;31m'
DIM   = '\033[0;90m'
RESET = '\033[0m'

STATE_COLOR = {
    'OPEN':   GREEN,
    'DRAFT':  YELLOW,
    'MERGED': MAGENTA,
    'CLOSED': RED,
}

ROOT_BRANCH = "develop"
CONFIG_FILE = ".pr-tree"

_repo_url   = None
_repo_owner = None
_repo_name  = None


def run(cmd):
    return subprocess.run(cmd, capture_output=True, text=True).stdout.strip()


def gh_json(args):
    result = subprocess.run(["gh"] + args, capture_output=True, text=True)
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return None


def get_repo_root():
    result = subprocess.run(["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True)
    return result.stdout.strip() if result.returncode == 0 else None


def load_root_branch():
    repo_root = get_repo_root()
    if not repo_root:
        return None
    config_path = os.path.join(repo_root, CONFIG_FILE)
    if os.path.exists(config_path):
        value = open(config_path).read().strip()
        return value if value else None
    return None


def save_root_branch(branch):
    repo_root = get_repo_root()
    if not repo_root:
        print("Warning: gitリポジトリが見つかりません", file=sys.stderr)
        return
    with open(os.path.join(repo_root, CONFIG_FILE), "w") as f:
        f.write(branch + "\n")
    print(f"設定を保存しました (root={branch})", file=sys.stderr)


def get_repo_info():
    global _repo_url, _repo_owner, _repo_name
    if _repo_url is None:
        data = gh_json(["repo", "view", "--json", "url,owner,name"])
        if data:
            _repo_url   = data["url"]
            _repo_owner = data["owner"]["login"]
            _repo_name  = data["name"]
        else:
            _repo_url = _repo_owner = _repo_name = ""


def branch_url(branch):
    get_repo_info()
    return f"{_repo_url}/tree/{quote(branch, safe='/')}"


_issue_cache = {}

def get_linked_issues(pr_number):
    if pr_number in _issue_cache:
        return _issue_cache[pr_number]
    get_repo_info()
    query = (
        f'{{ repository(owner:"{_repo_owner}", name:"{_repo_name}") '
        f'{{ pullRequest(number:{pr_number}) '
        f'{{ closingIssuesReferences(first:10) {{ nodes {{ number title url }} }} }} }} }}'
    )
    result = subprocess.run(
        ["gh", "api", "graphql", "-f", f"query={query}"],
        capture_output=True, text=True
    )
    issues = []
    if result.returncode == 0:
        try:
            data = json.loads(result.stdout)
            nodes = (data.get("data", {})
                        .get("repository", {})
                        .get("pullRequest", {})
                        .get("closingIssuesReferences", {})
                        .get("nodes", []))
            issues = nodes
        except (json.JSONDecodeError, AttributeError):
            pass
    _issue_cache[pr_number] = issues
    return issues


def effective_state(pr):
    if pr["state"] == "OPEN" and pr["isDraft"]:
        return "DRAFT"
    return pr["state"]


def state_badge(pr):
    state = effective_state(pr)
    color = STATE_COLOR.get(state, RESET)
    return f"{color}[{state.lower()}]{RESET}"


def load_all_prs():
    """gh pr list --state all で全PR一括取得"""
    print("PRツリーを取得中...", file=sys.stderr)
    data = gh_json([
        "pr", "list", "--state", "all",
        "--json", "number,title,state,isDraft,headRefName,baseRefName,url",
        "--limit", "500",
    ])
    return data or []


def build_maps(prs):
    head_to_pr  = {}
    base_to_prs = {}
    for pr in prs:
        head_to_pr[pr["headRefName"]] = pr
        base_to_prs.setdefault(pr["baseRefName"], []).append(pr)
    return head_to_pr, base_to_prs


def collect_chain(branch, head_to_pr):
    """branch から ROOT_BRANCH まで祖先チェーンを収集。
    各要素は (branch_name, pr_or_None)。先頭が ROOT_BRANCH。"""
    chain = []
    current = branch
    visited = set()

    while current and current != ROOT_BRANCH:
        if current in visited:
            break
        visited.add(current)
        pr = head_to_pr.get(current)
        chain.insert(0, (current, pr))
        if not pr:
            break
        current = pr["baseRefName"]

    chain.insert(0, (ROOT_BRANCH, None))
    return chain


# ===== CLI出力 =====

def print_subtree_cli(pr, prefix, is_last, base_to_prs, visited, target_branch):
    if pr["number"] in visited:
        return
    visited.add(pr["number"])

    connector    = "└── " if is_last else "├── "
    child_prefix = (prefix + "    ") if is_last else (prefix + "│   ")
    is_target    = (pr["headRefName"] == target_branch)

    badge = state_badge(pr)
    title_str  = f"{BOLD}{CYAN}{pr['title']}{RESET}" if is_target else pr["title"]
    branch_str = f"{BOLD}{CYAN}{pr['headRefName']}{RESET}" if is_target else f"{DIM}{pr['headRefName']}{RESET}"
    print(f"{prefix}{connector}{YELLOW}#{pr['number']}{RESET} {badge} {title_str}")
    print(f"{child_prefix}  {branch_str}")

    children = base_to_prs.get(pr["headRefName"], [])
    for i, child in enumerate(children):
        print_subtree_cli(child, child_prefix, i == len(children) - 1, base_to_prs, visited, target_branch)


def output_cli(chain, target_branch, head_to_pr, base_to_prs):
    visited_prs = set()
    root = chain[0][0]
    print(f"{BOLD}{root}{RESET}")

    if len(chain) < 2:
        return

    # L1: develop直下の一ノード
    l1_branch, l1_pr = chain[1]
    is_target = (l1_branch == target_branch)
    child_prefix = "    "

    if l1_pr:
        visited_prs.add(l1_pr["number"])
        badge = state_badge(l1_pr)
        title_str  = f"{BOLD}{CYAN}{l1_pr['title']}{RESET}" if is_target else l1_pr["title"]
        branch_str = f"{BOLD}{CYAN}{l1_branch}{RESET}" if is_target else f"{DIM}{l1_branch}{RESET}"
        print(f"└── {YELLOW}#{l1_pr['number']}{RESET} {badge} {title_str}")
        print(f"{child_prefix}  {branch_str}")
    else:
        branch_str = f"{BOLD}{CYAN}{l1_branch}{RESET}" if is_target else l1_branch
        print(f"└── {branch_str} {DIM}(no PR){RESET}")

    # L2以降: L1の全子孫を網羅表示（カレントブランチをハイライト）
    children = base_to_prs.get(l1_branch, [])
    for i, child in enumerate(children):
        print_subtree_cli(child, child_prefix, i == len(children) - 1, base_to_prs, visited_prs, target_branch)


